SERVER_PORT=18080
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:15432/sca
SPRING_DATASOURCE_USERNAME=sca
SPRING_DATASOURCE_PASSWORD=sca
SCA_TOKEN_SECRET=replace-with-random-secret
SCA_WORK_DIR=/tmp/sca-work
TRIVY_BIN=/usr/bin/trivy
SCA_TRIVY_SKIP_DB_UPDATE=true
SCA_SCAN_TIMEOUT_SECONDS=900
HOME=/root
XDG_CACHE_HOME=/root/.cache
